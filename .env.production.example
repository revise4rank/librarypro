BASE_DOMAIN=librarypro.com
WEB_APP_URL=https://app.librarypro.com
PORT=4000
API_COMPRESSION_ENABLED=true
JWT_SECRET=replace-with-a-32-plus-character-random-secret
JWT_ACCESS_TTL=15m
INTERNAL_TENANT_HEADER_SECRET=replace-with-a-different-32-plus-character-internal-secret
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/librarypro
DB_POOL_MAX=60
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=5000

# Upstash Redis
# Format example: rediss://default:<password>@<region>.upstash.io:6379
REDIS_URL=rediss://default:replace-with-upstash-password@replace-with-upstash-host:6379

# Upload provider: local | supabase
UPLOADS_PROVIDER=supabase
UPLOADS_DIR=uploads

# Supabase storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
SUPABASE_BUCKET=librarypro-assets

RAZORPAY_KEY_ID=replace-with-razorpay-key
RAZORPAY_KEY_SECRET=replace-with-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=replace-with-razorpay-webhook-secret
SENTRY_DSN=https://replace-with-sentry-dsn
OTEL_SERVICE_NAME=librarypro-api
OTEL_EXPORTER_OTLP_ENDPOINT=https://replace-with-otlp-endpoint/v1/traces
NOTIFICATION_WEBHOOK_URL=https://replace-with-your-notification-relay
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=reports@example.com
SMTP_PASS=replace-with-smtp-password
REPORT_FROM_EMAIL=reports@librarypro.com

NEXT_PUBLIC_API_URL=https://api.librarypro.com
NEXT_PUBLIC_BASE_DOMAIN=librarypro.com
NEXT_PUBLIC_WS_URL=wss://api.librarypro.com
